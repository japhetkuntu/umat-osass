# Copy this file to .env and populate secrets for production.
# Do not commit .env to source control.
#
# ── Deployment mode ───────────────────────────────────────────────────────────
# IP mode (no domain yet): uses nginx.ip.conf with port-based routing.
# Domain mode (after DNS + SSL): remove NGINX_CONF_FILE line entirely.
NGINX_CONF_FILE=./docker/nginx/nginx.ip.conf
SERVER_IP=45.222.48.15

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=OsassDb
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioapp
MINIO_ROOT_PASSWORD=minioapp
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=osass

JWT_ISSUER=http://45.222.48.15
JWT_AUDIENCE=http://45.222.48.15
JWT_APPLICANT_KEY=0078af695ad7b5f913d98ee75628638069873c6368c025e89980c70746e3b0d0
JWT_ADMIN_KEY=8679e98ce2a60a3ea2aab111f5df80207a8acda2c684c485adb06743a4252bc2e

EMAIL_PROVIDER=CustomEmail

STORAGE_ACCESS_KEY=minioapp
STORAGE_SECRET_KEY=minioapp
STORAGE_BUCKET=osass
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://minio:9000
STORAGE_CDN_ENDPOINT=http://45.222.48.15:9000

# ── Frontend URLs (baked into JS bundles at build time) ───────────────────────
# IP mode — use IP:port values below.
# Domain mode — uncomment the https:// lines and remove the http:// ones.
VITE_IDENTITY_API_URL=http://45.222.48.15:8081/api/v1
VITE_ACADEMIC_API_URL=http://45.222.48.15:8083/api/v1
VITE_NON_ACADEMIC_API_URL=http://45.222.48.15:8084/api/v1
VITE_ADMIN_API_URL=http://45.222.48.15:8082/api/v1

VITE_ACADEMIC_PORTAL_URL=http://45.222.48.15
VITE_LANDING_URL=http://45.222.48.15
VITE_NON_ACADEMIC_PORTAL_URL=http://45.222.48.15:8002
VITE_ACADEMIC_ASSESSMENT_PORTAL_URL=http://45.222.48.15:8003
VITE_NON_ACADEMIC_ASSESSMENT_PORTAL_URL=http://45.222.48.15:8004
VITE_ADMIN_PORTAL_URL=http://45.222.48.15:8001

# ── Domain mode (uncomment when DNS is live and SSL is provisioned) ───────────
