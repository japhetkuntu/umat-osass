# Copy this file to .env.production and populate secrets for production.
# Do not commit .env.production to source control.

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_IDENTITY_DB=OsassDb
POSTGRES_ACADEMIC_DB=AcademicPromotionDb
POSTGRES_NON_ACADEMIC_DB=NonAcademicPromotionDb
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioapp
MINIO_ROOT_PASSWORD=minioapp
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=osass

JWT_ISSUER=https://osass.umat.edu.gh
JWT_AUDIENCE=https://osass.umat.edu.gh
JWT_APPLICANT_KEY=replace_with_secure_random_key
JWT_ADMIN_KEY=replace_with_secure_random_key

EMAIL_PROVIDER=CustomEmail

STORAGE_ACCESS_KEY=minioapp
STORAGE_SECRET_KEY=minioapp
STORAGE_BUCKET=osass
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://minio:9000
STORAGE_CDN_ENDPOINT=http://minio:9000

VITE_IDENTITY_API_URL=https://auth.osass.umat.edu.gh/api/v1
VITE_ACADEMIC_API_URL=https://academic.osass.umat.edu.gh/api/v1
VITE_NON_ACADEMIC_API_URL=https://nonacademic.osass.umat.edu.gh/api/v1
VITE_ADMIN_API_URL=https://admin.osass.umat.edu.gh/api/v1
VITE_ACADEMIC_PORTAL_URL=https://academic.osass.umat.edu.gh
VITE_NON_ACADEMIC_PORTAL_URL=https://nonacademic.osass.umat.edu.gh
VITE_ACADEMIC_ASSESSMENT_PORTAL_URL=https://assessment.osass.umat.edu.gh
VITE_NON_ACADEMIC_ASSESSMENT_PORTAL_URL=https://nonacademic-assessment.osass.umat.edu.gh
VITE_ADMIN_PORTAL_URL=https://admin.osass.umat.edu.gh
