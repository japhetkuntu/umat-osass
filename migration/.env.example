MONGO_URI=mongodb://admin:admin@localhost:27018/LiveOsassDB?authSource=admin
# Or connect directly to the live v1 server:
# MONGO_URI=mongodb://MONGO_USER:MONGO_PASS@45.222.48.22:27017/LiveOsassDB

# PostgreSQL — Identity DB (Schools, Faculties, Departments, Staffs, Admins)
# Use port 5433 when running migration/docker-compose.yml, or 5432 for main docker-compose.yml
PG_IDENTITY_CONNECTION=postgresql://admin:admin@localhost:5433/OsassIdentityDb

# PostgreSQL — Academic Promotion DB (Positions, Applications, Committees)
PG_ACADEMIC_CONNECTION=postgresql://admin:admin@localhost:5433/AcademicPromotionDb

# Set to true to preview what would be inserted without writing to PG
DRY_RUN=false

# School name to create (should match what's shown in the v2 admin portal)
DEFAULT_SCHOOL_NAME=University of Mines and Technology

# Local folder root for the old v1 file uploads (optional - only needed to re-upload to MinIO)
# The v1 server stored files under {server}/public/data/*.pdf
OLD_FILES_ROOT=/Users/joe/Downloads/v1-backup/Backend

# MinIO / S3 settings used by the v2 system (optional - only needed for file re-upload)
MINIO_ENDPOINT=http://45.222.48.15:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=osass
MINIO_FOLDER=legacy
