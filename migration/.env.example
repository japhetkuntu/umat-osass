# Direct connection URI to the v1 MongoDB server
# Local container (migration/docker-compose.yml). Change to the production IP if seeding from live server.
MONGO_URI=mongodb://admin:admin@localhost:27018/LiveOsassDB?authSource=admin

# PostgreSQL — Identity DB
PG_IDENTITY_CONNECTION=postgresql://admin:admin@localhost:5432/OsassIdentityDb

# PostgreSQL — Academic Promotion DB
PG_ACADEMIC_CONNECTION=postgresql://admin:admin@localhost:5432/AcademicPromotionDb

# Set to true to preview what would be inserted without writing to PG
DRY_RUN=false

# School name to create (should match what's shown in the v2 admin portal)
DEFAULT_SCHOOL_NAME=University of Mines and Technology

# Local folder root for the old v1 file uploads (optional - only needed to re-upload to MinIO)
# The v1 files are stored flat in this directory (no public/data subfolder)
OLD_FILES_ROOT=/Users/joe/Downloads/v1-backup/data

# MinIO / S3 settings used by the v2 system (optional - only needed for file re-upload)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioapp
MINIO_SECRET_KEY=minioapp
MINIO_BUCKET=osass
MINIO_FOLDER=academic